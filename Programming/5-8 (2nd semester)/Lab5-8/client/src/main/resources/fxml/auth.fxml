<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15.0" styleClass="auth-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.Gh0st1yAnge1.gui.controllers.AuthController">

    <stylesheets>
        <URL value="@/css/style.css" />
    </stylesheets>

    <children>
        <Label fx:id="lblTitle" text="Route Manager" styleClass="auth-title">
            <VBox.margin>
                <Insets bottom="20.0" top="20.0" />
            </VBox.margin>
        </Label>

        <GridPane alignment="CENTER" hgap="10.0" vgap="10.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="120.0" minWidth="80.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="250.0" minWidth="180.0" prefWidth="220.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="30.0" prefHeight="35.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="30.0" prefHeight="35.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="30.0" prefHeight="35.0" vgrow="SOMETIMES" />
            </rowConstraints>

            <Label fx:id="lblLogin" text="Login:" styleClass="auth-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="tfLogin" styleClass="auth-input-field" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label fx:id="lblPassword" text="Password:" styleClass="auth-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <PasswordField fx:id="pfPassword" styleClass="auth-input-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label fx:id="lblLanguage" text="Language:" styleClass="auth-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <ComboBox fx:id="cbLanguage" styleClass="auth-combo-box" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        </GridPane>

        <HBox alignment="CENTER" spacing="20.0">
            <VBox.margin>
                <Insets top="15.0" />
            </VBox.margin>
            <children>
                <Button fx:id="btnLogin" text="Login" styleClass="auth-button" />
                <Button fx:id="btnRegister" text="Register" styleClass="auth-button" />
            </children>
        </HBox>

        <Label fx:id="lblMessage" styleClass="auth-error-message" wrapText="true">
            <VBox.margin>
                <Insets left="20.0" right="20.0" />
            </VBox.margin>
        </Label>
    </children>

    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
</VBox>